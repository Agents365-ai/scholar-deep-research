}

@article{qin2024efficacy,
  title = {Efficacy and safety of once-weekly tirzepatide for weight management compared to placebo: An updated systematic review and meta-analysis including the latest SURMOUNT-2 trial},
  author = {Wenhui Qin and Jun Yang and Ying Ni and Chao Deng and Qinjuan Ruan and Jun Ruan and Peng Zhou and Kai Duan},
