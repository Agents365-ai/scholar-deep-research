  journal = {International Journal of Obesity},
  year = {2024},
  doi = {10.1038/s41366-024-01473-y},
  url = {https://doi.org/10.1038/s41366-024-01473-y},
  abstract = {Obesity is a chronic disease associated with increased risk of obesity-related complications and mortality. Our better understanding of the weight regulation mechanisms and the role of gut-brain axis on appetite has led to the development of safe and effective entero-pancreatic hormone-based treatments for obesity such as glucagon-like peptide-1 (GLP-1) receptor agonists (RA). Semaglutide 2.4 mg once weekly, a subcutaneously administered GLP-1 RA approved for obesity treatment in 2021, results in 15-17\% mean weight loss (WL) with evidence of cardioprotection. Oral GLP-1 RA are also under development and early data shows similar WL efficacy to semaglutide 2.4 mg. Looking to the next generation of obesity treatments, combinations of GLP-1 with other entero-pancreatic hormones with complementary actions and/or synergistic potential (such as glucose-dependent insulinotropic polypeptide (GIP), glucagon, and amylin) are under investigation to enhance the WL and cardiometabolic benefits of GL}
}

